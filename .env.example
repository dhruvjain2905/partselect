# Copy this to .env and fill in your values

# Anthropic — used for the main agent (claude-sonnet-4-6) and guardrail (claude-haiku-4-5)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used only for embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Postgres — run `docker-compose up -d` to start a local instance
DATABASE_URL=postgresql://partselect:partselect@localhost:5432/partselect

# Model config (override if needed)
AGENT_MODEL=claude-sonnet-4-6
GUARDRAIL_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# Search tuning
SEMANTIC_SEARCH_LIMIT=8
SQL_RESULT_LIMIT=20
SQL_TIMEOUT_SECONDS=5
